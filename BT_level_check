class Solution:
    def check(self, root):
        leaf_level = [-1]

        def dfs(node, level):
            if node is None:
                return True

            if node.left is None and node.right is None:
                if leaf_level[0] == -1:
                    leaf_level[0] = level
                return level == leaf_level[0]

            return dfs(node.left, level + 1) and dfs(node.right, level + 1)

        return 1 if dfs(root, 0) else 0
