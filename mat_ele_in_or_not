def searchMatrix(mat, x):
    n = len(mat)
    m = len(mat[0])

    i = 0
    j = m - 1

    while i < n and j >= 0:
        if mat[i][j] == x:
            return 1
        elif mat[i][j] > x:
            j -= 1
        else:
            i += 1

    return 0


n, m = map(int, input().split())

mat = []
for _ in range(n):
    mat.append(list(map(int, input().split())))

x = int(input())

print(searchMatrix(mat, x))
